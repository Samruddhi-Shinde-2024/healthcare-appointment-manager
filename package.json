{
  "name": "healthcare-appointment-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present run build",
    "dev": "pnpm --parallel --filter @healthcare/client --filter @healthcare/server run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "prisma:generate": "pnpm --filter @healthcare/server run prisma:generate",
    "typecheck": "pnpm --recursive --if-present run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
